[Unit]
Description=Franklin race recorder (authoritative race model + DB writer)
Documentation=https://github.com/jachinrupe/franklin-lap-counter
After=franklin-redis.service franklin-hardware-monitor.service
Requires=franklin-redis.service
BindsTo=franklin-redis.service

[Service]
Type=simple
User=franklin
Group=franklin
WorkingDirectory=/opt/franklin-lap-counter
Environment=FRANKLIN_REDIS_SOCKET=/opt/franklin-lap-counter/run/redis.sock
ExecStart=/opt/franklin-lap-counter/lib/.venv/bin/python /opt/franklin-lap-counter/lib/franklin-race-recorder.py --db /opt/franklin-lap-counter/db/franklin.db
Restart=always
RestartSec=3

# Logging
StandardOutput=append:/var/log/franklin/franklin-race-recorder.log
StandardError=inherit

# Sandboxing
PrivateTmp=yes
ProtectSystem=full
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
