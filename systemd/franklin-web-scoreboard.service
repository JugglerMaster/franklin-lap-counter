[Unit]
Description=Franklin web scoreboard
Documentation=https://github.com/jachinrupe/franklin-lap-counter
After=franklin-redis.service
Requires=franklin-redis.service

[Service]
Type=simple
User=franklin
Group=franklin
WorkingDirectory=/opt/franklin-lap-counter
Environment=FRANKLIN_REDIS_SOCKET=/opt/franklin-lap-counter/run/redis.sock
ExecStart=/opt/franklin-lap-counter/lib/.venv/bin/python /opt/franklin-lap-counter/lib/scoreboard_web_app.py
Restart=always
RestartSec=3

# Logging
StandardOutput=append:/var/log/franklin/franklin-web-scoreboard.log
StandardError=inherit

# Sandboxing
PrivateTmp=yes
ProtectSystem=full
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
